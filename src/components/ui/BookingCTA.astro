---
export interface Props {
  title: string;
  description: string;
  href?: string;
}
const { title, description, href = '/idopontfoglalas' } = Astro.props;

// Május 2026 - 1-je péntekre esik
// offset: H=0, K=1, Sze=2, Cs=3, P=4 → 4 üres cella az elején
const days = ['H','K','Sze','Cs','P','Szo','V'];
const offset = 4; // május 1. = péntek
const totalDays = 31;
// Szabad napok (szimulált)
const available = [26, 27, 28, 29, 30];
const today = 23;
---

<section class="bg-brand py-16 lg:py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Bal: szöveg -->
      <div class="flex flex-col gap-6 text-white">
        <h2 class="text-3xl lg:text-4xl font-normal leading-tight">
          {title}
        </h2>
        <p class="text-white/80 leading-relaxed text-base">
          {description}
        </p>
        <a
          href={href}
          class="inline-flex items-center gap-2 self-start rounded-full bg-white text-brand hover:bg-white/90 px-8 py-3 text-sm font-semibold shadow-md transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Online időpontfoglalás
        </a>
      </div>

      <!-- Jobb: naptár kártya -->
      <div class="flex justify-center lg:justify-end">
        <div class="bg-white rounded-2xl p-6 shadow-xl w-full max-w-sm">
          <div class="flex items-center justify-between mb-5">
            <span class="text-sm font-semibold text-gray-900">2026. május</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>

          <!-- Napok fejléce -->
          <div class="grid grid-cols-7 mb-2">
            {days.map(d => (
              <span class="text-[11px] text-center text-gray-400 font-medium py-1">{d}</span>
            ))}
          </div>

          <!-- Naptár napok -->
          <div class="grid grid-cols-7 gap-y-1">
            <!-- Eltolás (péntek = 4. oszlop) -->
            {Array.from({ length: offset }).map(() => <span />)}

            {Array.from({ length: totalDays }).map((_, i) => {
              const d = i + 1;
              const isToday = d === today;
              const isAvailable = available.includes(d);
              const isPast = d < today;
              const isWeekend = (offset + i) % 7 >= 5;

              let cls = 'text-[13px] h-8 w-8 mx-auto flex items-center justify-center rounded-full font-medium transition-colors ';
              if (isToday) cls += 'bg-brand text-white';
              else if (isAvailable) cls += 'bg-brand-50 text-brand-dark font-semibold hover:bg-brand hover:text-white cursor-pointer';
              else if (isPast || isWeekend) cls += 'text-gray-300';
              else cls += 'text-gray-500';

              return <span class={cls}>{d}</span>;
            })}
          </div>

          <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between">
            <span class="text-xs text-gray-400 flex items-center gap-1.5">
              <span class="inline-block w-2.5 h-2.5 rounded-full bg-brand-50 border border-brand/30"></span>
              Szabad időpont
            </span>
            <a
              href={href}
              class="text-xs font-semibold text-brand hover:text-brand-dark transition-colors"
            >
              Összes időpont →
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
