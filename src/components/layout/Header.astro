---
const navStart = [
  { label: 'Főoldal', href: '/' },
  { label: 'Rólunk', href: '/rolunk' },
];

const navEnd = [
  { label: 'Árlista', href: '/arlista' },
  { label: 'Blog', href: '/blog' },
  { label: 'Kapcsolat', href: '/kapcsolat' },
];

const locations = [
  { label: 'Lélekliget Gyógycentrum Inárcs', href: '/szolgaltatasok/inarcs' },
  { label: 'Lélekliget Dabas', href: '/szolgaltatasok/dabas' },
];

const services = [
  { label: 'Összes szolgáltatás', href: '/szolgaltatasok', desc: 'Árak és összefoglaló' },
  { label: 'Funkcionális gyermekgyógyászat', href: '/szolgaltatasok/funkcionalis-gyermekgyogyaszat', desc: 'Inárcs · 35 000 Ft / 30 perc' },
  { label: 'Funkcionális belgyógyászat', href: '/szolgaltatasok/funkcionalis-belgyogyaszat', desc: 'Inárcs · 35 000 Ft / 30 perc' },
  { label: 'NLS diagnosztika', href: '/szolgaltatasok/nls-diagnosztika', desc: 'Dabas & Inárcs · 45 000 Ft / 90 perc' },
  { label: 'Kiegészítő terápiák', href: '/szolgaltatasok/kiegeszito-terapiak', desc: 'Dabas & Inárcs' },
];
---

<header class="sticky top-0 z-50 w-full bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img src="/logo.png" alt="Lélekliget logó" width="48" height="48" class="h-12 w-auto lg:h-14" />
        <span class="font-heading text-xl lg:text-2xl font-semibold tracking-tight text-black hidden sm:block">Lélekliget</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-8">
        {navStart.map((link) => (
          <a href={link.href} class="text-sm font-medium text-gray-700 hover:text-brand transition-colors">
            {link.label}
          </a>
        ))}

        <!-- Szolgáltatások dropdown -->
        <div class="relative">
          <button
            id="svc-btn"
            aria-expanded="false"
            class="flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-brand transition-colors"
          >
            Szolgáltatások
            <svg id="svc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>

          <div id="svc-dropdown" class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-80 bg-white rounded-2xl shadow-xl border border-gray-100 p-2 hidden z-50">
            {services.map((svc, i) => (
              <a href={svc.href} class={`flex flex-col gap-0.5 rounded-xl px-4 py-3 hover:bg-brand-50 transition-colors group${i === 0 ? ' border-b border-gray-100 mb-1' : ''}`}>
                <span class="text-sm font-medium text-gray-900 group-hover:text-brand transition-colors">{svc.label}</span>
                <span class="text-xs text-gray-500">{svc.desc}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Helyszínek dropdown -->
        <div class="relative">
          <button
            id="loc-btn"
            aria-expanded="false"
            class="flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-brand transition-colors"
          >
            Helyszínek
            <svg id="loc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>

          <div id="loc-dropdown" class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-72 bg-white rounded-2xl shadow-xl border border-gray-100 p-2 hidden z-50">
            {locations.map((loc) => (
              <a href={loc.href} class="flex rounded-xl px-4 py-3 hover:bg-brand-50 transition-colors group">
                <span class="text-sm font-medium text-gray-900 group-hover:text-brand transition-colors">{loc.label}</span>
              </a>
            ))}
          </div>
        </div>

        {navEnd.map((link) => (
          <a href={link.href} class="text-sm font-medium text-gray-700 hover:text-brand transition-colors">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + hamburger -->
      <div class="flex items-center gap-3">
        <a href="/idopontfoglalas" class="hidden sm:inline-flex btn-brand text-sm px-6 py-2">
          Időpontot foglalok
        </a>
        <button id="menu-btn" class="lg:hidden p-2 rounded-md text-gray-700 hover:text-brand" aria-label="Menü megnyitása" aria-expanded="false">
          <svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobil menü -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white px-4 pb-6 pt-4">
    <nav class="flex flex-col gap-1">
      {navStart.map((link) => (
        <a href={link.href} class="rounded-xl px-3 py-2.5 text-base font-medium text-gray-800 hover:text-brand hover:bg-brand-50 transition-colors">
          {link.label}
        </a>
      ))}

      <p class="px-3 pt-4 pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400">Szolgáltatások</p>
      {services.map((svc) => (
        <a href={svc.href} class="flex flex-col gap-0.5 rounded-xl px-3 py-2.5 hover:bg-brand-50 transition-colors">
          <span class="text-base font-medium text-gray-800">{svc.label}</span>
          <span class="text-xs text-gray-500">{svc.desc}</span>
        </a>
      ))}

      <p class="px-3 pt-4 pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400">Helyszínek</p>
      {locations.map((loc) => (
        <a href={loc.href} class="flex rounded-xl px-3 py-2.5 hover:bg-brand-50 transition-colors">
          <span class="text-base font-medium text-gray-800">{loc.label}</span>
        </a>
      ))}

      {navEnd.map((link) => (
        <a href={link.href} class="rounded-xl px-3 py-2.5 text-base font-medium text-gray-800 hover:text-brand hover:bg-brand-50 transition-colors">
          {link.label}
        </a>
      ))}

      <a href="/idopontfoglalas" class="btn-brand mt-3 w-full text-center">Időpontot foglalok</a>
    </nav>
  </div>
</header>

<script>
  // Hamburger
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', String(!mobileMenu?.classList.contains('hidden')));
  });

  function setupDropdown(btnId: string, dropdownId: string, chevronId: string) {
    const btn = document.getElementById(btnId);
    const dropdown = document.getElementById(dropdownId);
    const chevron = document.getElementById(chevronId);

    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = !dropdown?.classList.contains('hidden');
      // Zárd be a másik dropdownt
      document.querySelectorAll('[id$="-dropdown"]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[id$="-chevron"]').forEach(el => el.classList.remove('rotate-180'));
      document.querySelectorAll('[id$="-btn"]').forEach(el => el.setAttribute('aria-expanded', 'false'));
      if (!open) {
        dropdown?.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  }

  setupDropdown('svc-btn', 'svc-dropdown', 'svc-chevron');
  setupDropdown('loc-btn', 'loc-dropdown', 'loc-chevron');

  document.addEventListener('click', () => {
    document.querySelectorAll('[id$="-dropdown"]').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('[id$="-chevron"]').forEach(el => el.classList.remove('rotate-180'));
    document.querySelectorAll('[id$="-btn"]').forEach(el => el.setAttribute('aria-expanded', 'false'));
  });
</script>
