---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Oldal nem található | Lélekliget Gyógycentrum">
  <section class="flex-1 flex items-center justify-center py-32 px-4 text-center">
    <div class="max-w-md">
      <p class="text-8xl font-heading text-brand mb-6">404</p>
      <h1 class="text-2xl font-normal text-gray-900 mb-4">Ez az oldal nem található</h1>
      <p class="text-gray-500 mb-8 leading-relaxed">
        A keresett oldal nem létezik vagy elköltözött. Visszamehet a főoldalra.
      </p>
      <a href="/" class="btn-brand">Vissza a főoldalra</a>
    </div>
  </section>
</BaseLayout>
