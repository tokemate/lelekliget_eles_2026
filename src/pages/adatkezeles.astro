>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-normal text-gray-900 mb-8">Adatkezelési Tájékoztató</h1>
    <div class="prose prose-gray max-w-none">
      <p class="text-gray-500">Az adatkezelési tájékoztató hamarosan elérhető lesz.</p>
    </div>
  </div>
</BaseLayout>
