---
import BaseLayout from '../layouts/BaseLayout.astro';

const teamMembers = [
  {
    name: 'Petrányi Zsoltné Ildikó',
    role: 'Masszőr',
    photo: '/images/petranyi-zsoltne-ildiko.webp',
    quote: 'Energetikai, talp- és nyirokmasszázs, thai masszázs a test és a lélek harmóniájáért – támogassa szervezete öngyógyító folyamatait és méregtelenítését!',
    description: 'Hiszem, hogy a test és a lélek egységet alkot, és a valódi feltöltődés akkor történik meg, amikor mindkettő harmóniába kerül. Kezeléseim során ezt az egyensúlyt segítem visszaállítani, figyelemmel, jelenléttel és személyre szabott megközelítéssel. Az energetikai masszázs oldja a belső blokkokat és támogatja az energia szabad áramlását. A talpmasszázs a test egészére hat – a talpon keresztül kapcsolódunk a szervezet különböző pontjaihoz, így támogatva az öngyógyító folyamatokat. A nyirokmasszázs kíméletesen segíti a méregtelenítést, csökkenti a feszültséget és hozzájárul a szervezet természetes egyensúlyához. Fontos számomra, hogy minden vendégem biztonságban, elfogadásban és nyugalomban érezze magát, és valódi feltöltődést tapasztalhasson.',
  },
  {
    name: 'Udvardi Zsuzsanna',
    role: 'Természetgyógyász, fülakupunktúrás addiktológus',
    photo: '/images/udvardi-zsuzsanna.webp',
    quote: 'Lépjen a változás útjára: csökkentse a stresszt, győzze le a sóvárgást diszkrét fülakupunktúrával, és töltődjön fel a tiszta esszenciális illóolajok érintésével.',
    description: 'Hiszem, hogy a test és a lélek egyensúlya visszaállítható, és ehhez kínálok hatékony, gyengéd támogatást. Fülakupunktúrás addiktológia: ha felismerted magadon az addikció jeleit – dohányzás, alkohol, étkezési zavarok, kényszeres szokások –, és szeretnél változtatni, de nem szívesen beszélsz róla, ez a módszer neked szól. A kezelés teljesen diszkrét, csökkenti a sóvárgást, enyhíti a feszültséget és támogatja a méregtelenítést. doTERRA AromaTouch™ terápia: egy különleges, mélyen ellazító kezelés, amely során nyolcféle tiszta, terápiás minőségű esszenciális illóolajat viszek fel a hátadra és a talpaidra – az érintés és az illatok erejével csökkenti a stresszt, erősíti az immunrendszert és támogatja a szervezet öngyógyító folyamatait.',
  },
  {
    name: 'Czank Edina',
    role: 'Asszisztens',
    photo: '/images/czank-edina.webp',
    quote: 'Szeretettel köszöntöm!',
    description: 'Egészségügyi és szépségápolási területen szerzett tapasztalataimmal két orvos munkáját segítem asszisztensként felnőtt-, gyermek- és holisztikus szemléletű rendelésen. Hivatásom középpontjában mindig az ember áll: fontos számomra, hogy a hozzánk fordulók figyelmet, támogatást és biztonságot kapjanak. Végzettségeim – ápoló, kozmetikus, testkezelő – során megtanultam, hogy a testi egészség és a lelki egyensúly szorosan összekapcsolódik. Szabadidőmben rendszeresen jógázom, amely segít megőrizni a harmóniát és a tudatos jelenlétet. Célom, hogy kedvességgel és empátiával támogassam pácienseinket, hogy mindenki bizalommal fordulhasson hozzánk.',
  },
  {
    name: 'Molnárné Szabó Kati',
    role: 'Családállítás · Tarot · Ingás oldás',
    photo: '/images/molnarne-szabo-kati.jpg',
    photoPosition: 'center 35%',
    quote: '',
    description: 'Tegyük meg együtt az első lépést a rálátás, a megismerés és az elfogadás felé. Családállítás, Tarot, Ingás oldás és még sok mással várlak a Lélekligetben. Mert az élet szép.',
    website: 'https://www.eletszepito.hu',
  },
];
---

<BaseLayout
  title="Rólunk | Lélekliget Gyógycentrum"
  description="Ismerje meg rendelőnk történetét, szakmai hátterét és a holisztikus gyógyítás iránti elkötelezettségünket."
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-6">
        Akik az Ön és családja egészségét kísérik
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Ismerje meg rendelőnk történetét, szakmai hátterét és a holisztikus gyógyítás iránti elkötelezettségünket.
      </p>
    </div>
  </section>

  <!-- ═══ TÖRTÉNETÜNK ═══ -->
  <section class="py-20 px-4">
    <div class="mx-auto max-w-3xl flex flex-col gap-10">
      <div class="flex flex-col gap-4">
        <span class="inline-flex items-center justify-center rounded-full bg-brand-50 border border-brand/20 px-4 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark w-fit mx-auto">
          Történetünk
        </span>
        <h2 class="text-3xl sm:text-4xl font-normal text-gray-900 leading-snug text-center">
          Amikor a szakmai elhivatottság és a barátság találkozik
        </h2>
      </div>
      <p class="text-gray-600 leading-relaxed text-lg text-center">
        Dr. Piri Anikó és Dr. Ágoston Krisztina orvosi pályáját mindig is egy közös vonás kísérte:
        a nyitottság a természetes és alternatív gyógymódok irányába. Történetünk Anikó rendelőjében
        kezdődött, ahol az első találkozás alkalmával kiderült, hogy nemcsak szakmailag, de emberileg
        is tökéletesen egy hullámhosszon vannak. Ebből a szakmai kapcsolódásból az évek során egy
        töretlen, mély barátság fejlődött ki.
      </p>
      <p class="text-gray-500 leading-relaxed text-base text-center">
        A rendelő ötletét Dr. Piri Anikó álmodta meg, és 2024 szeptembere óta töretlen energiával
        építi és szépíti ezt a gyógyító teret.
      </p>

      <!-- Közös küldetés -->
      <div class="bg-brand-50 rounded-2xl px-8 py-10 flex flex-col gap-4 text-center border border-brand/10">
        <h3 class="text-xl font-medium text-gray-900">A mi közös küldetésünk</h3>
        <p class="text-gray-600 leading-relaxed">
          Nem csupán különálló orvosokként, hanem együttműködő csapatként állunk a hozzánk fordulók
          mellett. Célunk, hogy támogassuk Önt és családját az egészség helyrehozásában, hosszú távú
          megtartásában, valamint a krónikus betegségek tudatos megelőzésében.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CSAPAT ═══ -->
  <section class="bg-brand-50 py-24 px-4">
    <div class="mx-auto max-w-5xl flex flex-col gap-20">

      <!-- Dr. Piri Anikó — fotó bal, szöveg jobb -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div class="w-full rounded-2xl overflow-hidden">
          <img
            src="/images/dr-piri-aniko.webp"
            alt="Dr. Piri Anikó"
            class="w-full h-full object-cover object-top rounded-2xl"
            style="max-height: 520px"
          />
        </div>
        <div class="flex flex-col gap-6">
          <span class="inline-flex w-fit items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-medium text-brand-dark">
            Holisztikus szemléletű gyermekgyógyász
          </span>
          <h3 class="text-2xl sm:text-3xl font-normal text-gray-900">Dr. Piri Anikó</h3>
          <blockquote class="border-l-4 border-brand pl-5 py-2">
            <p class="text-gray-700 italic leading-relaxed">
              „Hiszem, hogy a tudás soha véget nem érő folyamat, a gyógyítás pedig akkor a leghatékonyabb, ha a tudomány és a természet kezet fog egymással."
            </p>
          </blockquote>
          <p class="text-gray-600 leading-relaxed">
            Dr. Piri Anikó vagyok, csecsemő- és gyermekgyógyász, háromgyermekes édesanya. Az utam során
            a saját gyermekeimen tapasztaltam meg először azt az erőt, amit a hagyományos orvoslás és a
            természetes gyógymódok ötvözése jelent. Felismertem, hogy a két terület egymást kiegészítve
            sokkal nagyobb hatékonysággal működik, mint külön-külön.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Éveken át saját és helyettesített praxisaimban csiszoltam ezt a szemléletet, mindig a „miért?"
            kérdést kutatva. Kellő kíváncsisággal és a betegeim érdekeit szem előtt tartva tanultam és
            fejlődtem, hogy ne csak a tüneteket kezeljem, hanem az egész embert lássam.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Első álmom a dabasi Lélekliget megalapításával vált valóra. A csapattal közösen azonban tovább
            álmodtunk: eljött az idő, hogy magánrendelésem keretében még szélesebb körben, még több család
            számára tegyem elérhetővé a holisztikus szemléletű gyógyászati ellátást és egészségmegőrzést.
            Várom mindazokat, akik gyógyulni szeretnének, és azokat is, akik tenni akarnak az egészségük
            hosszú távú fenntartásáért.
          </p>
        </div>
      </div>

      <!-- Dr. Ágoston Krisztina — szöveg bal, fotó jobb -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div class="flex flex-col gap-6 order-2 lg:order-1">
          <span class="inline-flex w-fit items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-medium text-brand-dark">
            Holisztikus szemléletű orvos
          </span>
          <h3 class="text-2xl sm:text-3xl font-normal text-gray-900">Dr. Ágoston Krisztina</h3>
          <blockquote class="border-l-4 border-brand pl-5 py-2">
            <p class="text-gray-700 italic leading-relaxed">
              „Klinikai tapasztalattal és holisztikus szemlélettel kísérem Önt a személyre szabott, természetes gyógyulás és a tudatos megelőzés útján."
            </p>
          </blockquote>
          <p class="text-gray-600 leading-relaxed">
            Dr. Ágoston Krisztina vagyok, kétgyermekes édesanya. Már a kórházi munkám során egyre inkább
            azt tapasztaltam, hogy a valódi gyógyulás sokkal hatékonyabb és tartósabb, ha nem csupán
            egy-egy kiragadott tünetet kezelünk, hanem az embert egészében nézzük – testet, lelket és
            szellemet együtt. Ez az út vezetett oda, hogy a klinikai munkát magam mögött hagyva alternatív,
            holisztikus szemléletű megoldásokat kezdjek keresni és tanulni. Többek között elvégeztem az
            Új Germán Medicina és a Recall Healing képzéseit is, hogy még mélyebben megérthessem a
            betegségek mögött húzódó összefüggéseket és okokat.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Gyermekeim megszületése után még fontosabbá vált számomra, hogy minél természetesebb módon
            támogassuk a szervezetet, lehetőleg minél kevesebb gyógyszerrel. Hiszem, hogy a legjobb
            gyógyítás a megelőzés, és hogy minden ember egyedi: ami az egyik embernek segítség, a másiknak
            nem feltétlenül az. Éppen ezért számomra a személyre szabott megközelítés alapvető.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Nem csodát és nem csodaszert ígérek. Abban szeretnék segíteni, hogy közösen megtaláljuk a
            problémák valódi okát, ne csak a tüneteket próbáljuk elnyomni vagy „tüzet oltani". Hiszem,
            hogy a szervezet képes az öngyógyulásra, ha megfelelő támogatást kap — én ebben szeretném
            kísérni és támogatni a hozzám fordulókat.
          </p>
        </div>
        <div class="w-full rounded-2xl overflow-hidden order-1 lg:order-2">
          <img
            src="/images/dr-agoston-krisztina.webp"
            alt="Dr. Ágoston Krisztina"
            class="w-full h-full object-cover object-top rounded-2xl"
            style="max-height: 520px"
          />
        </div>
      </div>

      <!-- 4 kártyás grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {teamMembers.map((member, i) => {
          const dotIdx = member.description.indexOf('. ');
          const first = dotIdx !== -1 ? member.description.slice(0, dotIdx + 1) : member.description;
          const rest = dotIdx !== -1 ? member.description.slice(dotIdx + 2) : '';
          return (
            <div class="overflow-hidden rounded-2xl shadow-sm bg-white flex flex-col">
              <div class="aspect-square w-full overflow-hidden">
                <img
                  src={member.photo}
                  alt={member.name}
                  class="w-full h-full object-cover"
                  style={`object-position: ${member.photoPosition ?? 'center top'}`}
                />
              </div>
              <div class="p-6 flex flex-col gap-3 flex-1">
                <h3 class="text-lg font-medium text-gray-900">{member.name}</h3>
                <span class="inline-flex w-fit items-center rounded-full bg-brand-light px-3 py-0.5 text-xs font-medium text-brand-dark leading-tight">
                  {member.role}
                </span>
                <p class="text-sm text-gray-600 leading-relaxed">
                  {first}
                  {rest && (
                    <span id={`rest-${i}`} hidden>
                      {' '}{rest}
                      {member.website && (
                        <> <a href={member.website} target="_blank" rel="noopener noreferrer" class="text-brand underline italic hover:text-brand-dark transition-colors">további infó</a></>
                      )}
                    </span>
                  )}
                </p>
                {rest && (
                  <button
                    id={`toggle-${i}`}
                    class="w-fit text-sm text-brand italic underline hover:text-brand-dark transition-colors text-left"
                    onclick={`var r=document.getElementById('rest-${i}'),b=document.getElementById('toggle-${i}'),open=!r.hidden;r.hidden=open;b.textContent=open?'Még több':'Még kevesebb';`}
                  >Még több</button>
                )}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- doTERRA -->
  <section class="py-20 px-4">
    <div class="mx-auto max-w-3xl">
      <div class="bg-brand-light rounded-2xl px-8 py-14 text-center flex flex-col items-center gap-6">
        <p class="text-xs font-semibold tracking-widest text-brand-dark uppercase">
          Természetes megoldások a mindennapi élethez
        </p>
        <h2 class="text-3xl font-normal text-gray-900">Természetes megoldások a mindennapi élethez</h2>
        <p class="text-gray-700 leading-relaxed max-w-xl">
          Rendelőnk kiemelt partnere a doTERRA, a világ vezető illóolaj-gyártója. Hiszünk abban,
          hogy a természet ereje hatékony kiegészítője lehet a gyógyulási folyamatnak és a
          megelőzésnek egyaránt. Ismerje meg tiszta, terápiás minőségű megoldásainkat.
        </p>
        <a
          href="#"
          class="inline-flex items-center rounded-full border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white px-6 py-2 text-sm font-medium transition-colors"
        >
          Tovább a doTERRA oldalra →
        </a>
      </div>
    </div>
  </section>

  <!-- BEMER -->
  <section class="pb-20 px-4">
    <div class="mx-auto max-w-3xl">
      <div class="bg-brand-light rounded-2xl px-8 py-14 text-center flex flex-col items-center gap-6">
        <p class="text-xs font-semibold tracking-widest text-brand-dark uppercase">
          Mikrocirkuláció & sejt szintű regeneráció
        </p>
        <h2 class="text-3xl font-normal text-gray-900">A BEMER terápia ereje</h2>
        <p class="text-gray-700 leading-relaxed max-w-xl">
          Rendelőnk hivatalos BEMER kezelőhely. A készülék a fizikai érterápia egyedüli,
          világszintű vezető márkája. A BEMER-készülékek egyedülálló jelformájukkal támogatják
          a szervezet természetes öngyógyító folyamatait, javítják a vérkeringést és elősegítik
          a regenerációt. Ismerje meg innovatív megoldásainkat.
        </p>
        <a
          href="https://accomed.bemergroup.com/hu_HU/human-line/kezdolap"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white px-6 py-2 text-sm font-medium transition-colors"
        >
          Tovább a BEMER oldalra →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
