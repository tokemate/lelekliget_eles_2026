---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Gyermekgyógyászat',
    items: [
      { name: 'Funkcionális gyermekorvosi vizit',       price: '35 000', unit: 'Ft' },
      { name: 'Általános gyermekorvosi vizit',          price: '20 000', unit: 'Ft' },
      { name: 'NLS állapotfelmérés',                   price: '45 000', unit: 'Ft' },
      { name: 'Arcüregátmosás',                        price: '15 000', unit: 'Ft' },
      { name: 'GOH',                                   price: '5 000',  unit: 'Ft' },
      { name: 'EWS Analyser',                          price: '20 000', unit: 'Ft' },
      { name: 'Kontroll NLS állapotfelmérés',          price: '40 000', unit: 'Ft' },
      { name: 'Kontroll – orvosi vizit 3 hónapon belül', price: '20 000', unit: 'Ft' },
      { name: 'Hozott lelet kiértékelése',             price: '10 000', unit: 'Ft' },
    ],
  },
  {
    title: 'Felnőtt belgyógyászat',
    items: [
      { name: 'Felnőtt funkcionális belgyógyászati vizit',          price: '35 000', unit: 'Ft' },
      { name: 'Általános felnőtt orvosi vizit',                     price: '25 000', unit: 'Ft' },
      { name: 'ABPM vizsgálat',                                     price: '15 000', unit: 'Ft' },
      { name: 'ABPM vizsgálat, értékelés',                          price: '20 000', unit: 'Ft' },
      { name: 'NLS állapotfelmérés',                                price: '45 000', unit: 'Ft' },
      { name: 'Arcüregátmosás',                                     price: '15 000', unit: 'Ft' },
      { name: 'Kontroll belgyógyászati vizsgálat 3 hónapon belül',  price: '20 000', unit: 'Ft' },
      { name: 'Kontroll NLS',                                       price: '40 000', unit: 'Ft' },
    ],
  },
  {
    title: 'Egyéb szolgáltatások',
    items: [
      { name: 'BEMER bérlet',              note: '1 kezelés 3 500 Ft · 10+1 alkalom bérlet', price: '25 000', unit: 'Ft / hét' },
      { name: 'Symphony Of Cells bérlet',  note: 'heti 3 × 10 perc',                          price: '–',       unit: '' },
      { name: 'Gyógyszer felírás, igazolás kiadás', price: '5 000', unit: 'Ft' },
      { name: 'Energetikai kezelés',       note: '60 perc',  price: '10 000', unit: 'Ft' },
      { name: 'Nyirokmasszázs',            note: '90 perc',  price: '15 000', unit: 'Ft' },
      { name: 'Svédmasszázs',              note: '60 perc',  price: '10 000', unit: 'Ft' },
      { name: 'AromaTouch',               note: '30 perc',  price: '15 000', unit: 'Ft' },
      { name: 'Fülakupunktúra',           price: '–',        unit: '' },
    ],
  },
];
---

<BaseLayout
  title="Árlista | Lélekliget Gyógycentrum"
  description="Lélekliget Gyógycentrum szolgáltatásainak árlista – gyermekgyógyászat, belgyógyászat, kiegészítő terápiák."
>

  <!-- Hero -->
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-4">Árlista</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Szolgáltatásaink aktuális díjszabása. Az árak tájékoztató jellegűek.
      </p>
    </div>
  </section>

  <!-- Kategóriák -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-4xl flex flex-col gap-16">

      {categories.map((cat) => (
        <div>
          <!-- Kategória cím -->
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-2xl font-normal text-gray-900 whitespace-nowrap">{cat.title}</h2>
            <div class="flex-1 h-px bg-brand/20"></div>
          </div>

          <!-- Kártyák -->
          <div class="flex flex-col gap-2">
            {cat.items.map((item) => (
              <div class="flex items-center justify-between gap-4 rounded-xl border border-gray-100 bg-white px-5 py-4 hover:border-brand/30 hover:shadow-sm transition-all">
                <div class="flex flex-col gap-0.5">
                  <span class="text-sm font-medium text-gray-900">{item.name}</span>
                  {item.note && (
                    <span class="text-xs text-gray-400">{item.note}</span>
                  )}
                </div>
                <div class="flex items-baseline gap-1 shrink-0">
                  <span class="text-lg font-semibold text-brand">{item.price}</span>
                  {item.unit && (
                    <span class="text-xs text-gray-400">{item.unit}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <p class="text-center text-sm text-gray-400">
        Az árak tájékoztató jellegűek. Pontosabb díjszabásért kérjük, vegye fel velünk a
        <a href="/kapcsolat" class="text-brand hover:underline">kapcsolatot</a>.
      </p>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand py-16 px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-normal text-white mb-4">Foglaljon időpontot</h2>
      <p class="text-white/80 leading-relaxed mb-8">Válassza ki az Önnek megfelelő helyszínt és időpontot.</p>
      <a href="/idopontfoglalas" class="inline-flex items-center gap-2 rounded-full bg-white text-brand hover:bg-white/90 px-8 py-3 text-sm font-semibold transition-colors">
        Időpontot foglalok
      </a>
    </div>
  </section>

</BaseLayout>
