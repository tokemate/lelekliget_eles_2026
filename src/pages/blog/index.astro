---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Blog | Lélekliget Gyógycentrum"
  description="Hasznos cikkek az egészségmegőrzésről, holisztikus gyógyításról és természetes életmódról."
>
  <section class="bg-brand-50 py-16 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-4">Blog</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Hasznos tartalmak az egészségmegőrzésről és a holisztikus életmódról.
      </p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="mx-auto max-w-5xl">

      {posts.length > 0 && (
        <div class="mb-10 max-w-md mx-auto">
          <div class="relative">
            <svg
              class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
              width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              id="blog-search"
              type="search"
              placeholder="Keresés a cikkek között…"
              autocomplete="off"
              class="w-full rounded-2xl border border-gray-200 bg-white pl-11 pr-4 py-3 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand transition"
            />
          </div>
        </div>
      )}

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-500 text-lg">Hamarosan érkeznek az első cikkek.</p>
        </div>
      ) : (
        <>
          <div id="blog-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <article
                class="group flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden hover:shadow-md transition-shadow"
                data-title={post.data.title.toLowerCase()}
                data-excerpt={(post.data.excerpt ?? '').toLowerCase()}
                data-category={(post.data.category ?? '').toLowerCase()}
              >
                <div class="w-full h-44 bg-brand-light flex items-center justify-center relative">
                  {post.data.coverImage ? (
                    <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover" />
                  ) : (
                    <>
                      <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent"></div>
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="relative opacity-40">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </>
                  )}
                </div>
                <div class="p-5 flex flex-col gap-3 flex-1">
                  <h2 class="text-base font-normal text-black leading-snug group-hover:text-brand transition-colors">
                    {post.data.title}
                  </h2>
                  {post.data.excerpt && (
                    <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{post.data.excerpt}</p>
                  )}
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-brand hover:text-brand-dark transition-colors mt-auto"
                  >
                    Olvasom
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>

          <p id="no-results" class="hidden text-center text-gray-500 py-16 text-base">
            Nincs találat erre a keresésre.
          </p>
        </>
      )}

    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('blog-search') as HTMLInputElement | null;
  const grid = document.getElementById('blog-grid');
  const noResults = document.getElementById('no-results');

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    const cards = grid?.querySelectorAll<HTMLElement>('article');
    let visible = 0;

    cards?.forEach((card) => {
      const matches =
        !q ||
        card.dataset.title?.includes(q) ||
        card.dataset.excerpt?.includes(q) ||
        card.dataset.category?.includes(q);

      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });

    noResults?.classList.toggle('hidden', visible > 0);
  });
</script>
