---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Funkcionális Gyermekgyógyászat',
    description: 'A várandósságtól kezdődően prevenciós tanácsadás a korai megelőzésért, ellátás a legkisebbeknek, a megelőzéstől az akut betegségek szakszerű kezeléséig. Rendszeres szűrővizsgálatok, holisztikus szemléletű tanácsadás és terápia.',
    href: '/szolgaltatasok/inarcs',
    location: 'Inárcs',
    priceLabel: 'Konzultációs díj',
    price: '35 000',
    priceNote: 'Ft / 30 perc',
  },
  {
    title: 'Funkcionális Belgyógyászat',
    description: 'Rendelésünkön teljes körű belgyógyászati vizsgálat, okfeltárás a gyökerektől, holisztikus kezelési terv az Ön egészsége érdekében.',
    href: '/szolgaltatasok/inarcs',
    location: 'Inárcs',
    priceLabel: 'Konzultációs díj',
    price: '35 000',
    priceNote: 'Ft / 30 perc',
  },
  {
    title: 'NLS diagnosztika',
    description: 'Non-invazív teljes test energetikai állapotfelmérés a szervezet információs mezőinek elemzésével. Korai felismerés fájdalom nélkül. Orvosi holisztikus tanácsadás és kezelési terv.',
    href: '/szolgaltatasok/dabas',
    location: 'Dabas & Inárcs',
    priceLabel: 'Vizsgálati díj',
    price: '45 000',
    priceNote: 'Ft / 90 perc',
  },
  {
    title: 'Kiegészítő terápiák',
    description: 'Masszázs, akupunktúra, energiagyógyászat, BEMER terápia, esszenciális olajok, családállítás, csontkovács.',
    href: '/szolgaltatasok/dabas',
    location: 'Dabas & Inárcs',
    priceLabel: 'Kezelési díj',
    price: '–',
    priceNote: '',
  },
];
---

<BaseLayout
  title="Szolgáltatások | Lélekliget Gyógycentrum"
  description="Gyermekgyógyászat, funkcionális orvoslás, NLS diagnosztika és kiegészítő terápiák Inárcson és Dabasban."
>
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-6">Szolgáltatásaink</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Holisztikus szemlélettel, modern eszközökkel — két helyszínen az Ön és családja egészségéért.
      </p>
    </div>
  </section>

  <section class="py-20 px-4">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {services.map((s) => (
          <a
            href={s.href}
            class="group flex flex-col gap-4 rounded-2xl border border-gray-100 bg-white p-8 hover:border-brand/30 hover:shadow-md transition-all"
          >
            <!-- Cím + helyszín -->
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-xl font-normal text-black group-hover:text-brand transition-colors leading-snug">{s.title}</h2>
              <span class="inline-flex items-center rounded-full bg-brand-50 px-3 py-0.5 text-xs font-medium text-brand-dark shrink-0 mt-0.5">
                {s.location}
              </span>
            </div>

            <!-- Leírás -->
            <p class="text-sm text-gray-600 leading-relaxed">{s.description}</p>

            <!-- Ár -->
            <div class="mt-auto pt-5 border-t border-gray-100 flex items-end justify-between gap-4">
              <div class="flex flex-col gap-0.5">
                <span class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">{s.priceLabel}</span>
                <div class="flex items-baseline gap-1.5">
                  <span class="text-2xl font-semibold text-brand leading-none">{s.price}</span>
                  {s.price !== '–' && (
                    <span class="text-sm text-gray-400">{s.priceNote}</span>
                  )}
                  {s.price === '–' && (
                    <span class="text-sm text-gray-400">Hamarosan</span>
                  )}
                </div>
              </div>
              <span class="inline-flex items-center gap-1.5 text-sm font-medium text-brand shrink-0">
                Részletek
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Árajánlat megjegyzés -->
      <p class="mt-8 text-center text-sm text-gray-400">
        Az árak tájékoztató jellegűek. Pontos díjszabásért kérjük, vegye fel velünk a
        <a href="/kapcsolat" class="text-brand hover:underline">kapcsolatot</a>.
      </p>
    </div>
  </section>

  <section class="bg-brand py-16 px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-normal text-white mb-4">Foglaljon időpontot</h2>
      <p class="text-white/80 leading-relaxed mb-8">
        Válassza ki az Önnek megfelelő helyszínt és időpontot.
      </p>
      <a href="/idopontfoglalas" class="inline-flex items-center gap-2 rounded-full bg-white text-brand hover:bg-white/90 px-8 py-3 text-sm font-semibold transition-colors">
        Időpontot foglalok
      </a>
    </div>
  </section>
</BaseLayout>
