---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';

const gyermekList = [
  'Rendszeres csecsemő- és gyermekvizsgálatok: az egyéni fejlődési ritmust és a megelőzést előtérbe helyező szűrések.',
  'Személyre szabott életmód-tanácsadás: szakértő támogatás a táplálkozás, a mozgás és a lelki fejlődés kérdéseiben.',
  'Családközpontú szemlélet: partneri együttműködés és tanácsadás a szülőknek a mindennapok harmóniájáért.',
  'Barátságos, stresszmentes környezet: ahol a kicsik biztonságban és otthonosan érezhetik magukat.',
];

const belgyList = [
  'Oknyomozó diagnosztika: nem elégszünk meg a felszíni tünetek enyhítésével; részletes elemzéssel keressük a krónikus panaszok, fáradékonyság vagy emésztési problémák valódi kiváltó okait.',
  'Személyre szabott, holisztikus terápia: egyedi kezelési tervet állítunk össze, amely a célzott orvosi támogatás mellett a táplálkozásra, a bélflóra helyreállítására és az életmódra is kiterjed.',
  'Testi-lelki egyensúly és prevenció: nagy hangsúlyt fektetünk a megelőzésre és a stressz szervezetünkre gyakorolt hatásainak kezelésére, támogatva a hosszan tartó vitalitást.',
  'Időt szánunk Önre: nálunk a vizsgálat egy alapos, rohanásmentes beszélgetéssel kezdődik, ahol a páciens áll a középpontban.',
];

const arcuregList = [
  'Gyökérokok feltárása: a felső légúti panaszokat nem elszigetelten, hanem a teljes szervezet összefüggéseiben vizsgáljuk a teljes gyógyulásért.',
  'Komplex arcüreggyulladás-kezelés: visszatérő panaszok megszüntetése speciális technikával.',
  'Viselkedési zavarok és rejtett halláscsökkenés: kiszűrjük a háttérben meghúzódó szubklinikus hallászavarokat, amelyek a gyermekkori magatartási és figyelmi problémák mögött állhatnak GOH-val.',
  'Horkolás: a rejtett okok megszüntetése gyermekeknél és felnőtteknél.',
];

const nlsList = [
  'Non-invazív, sejtszintű állapotfelmérés: tűszúrás és sugárterhelés nélkül, elektromágneses hullámok segítségével térképezi fel a szervezet, a szervek és a sejtek pillanatnyi funkcionális állapotát.',
  'Korai felismerés: képes kimutatni az elváltozásokat még azelőtt, hogy azok fizikai tünetként vagy laboratóriumi eltérésként megjelennének, így a prevenció (megelőzés) legerősebb eszköze.',
  'Holisztikus összefüggések feltárása: nemcsak egy szervet néz, hanem az egész szervezetet.',
  'Személyre szabott terápiás támogatás: segít pontosan meghatározni, hogy a páciens szervezetének milyen vitaminokra, nyomelemekre vagy egyéni életmódváltásra van szüksége a belső egyensúly visszaállításához.',
  'Gyermek- és felnőttbarát technológia: teljesen fájdalom- és stresszmentes (egy speciális fejhallgató segítségével zajlik), így kisgyermekeknél is kiválóan alkalmazható.',
  'Vizuális eredmények: a vizsgálat során a páciens (és a szülő) a monitoron, 3D-s ábrákon keresztül, azonnal láthatja a teste energetikai és funkcionális visszajelzéseit.',
];
---

<BaseLayout
  title="Inárcsi Magánrendelő | Lélekliget"
  description="Általános orvosi rendelés, alternatív diagnosztika és terápia, fókuszban az arcüreggyulladással. Természetközeli helyszín, ingyenes parkoló, könnyen megközelíthető az M5-ről."
>

  <!-- ═══ HERO ═══ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    style="background-image: url('/images/inarcs/inarcs-epulet.jpg'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 flex flex-col items-center gap-7 max-w-3xl px-4 sm:px-6">
      <span class="inline-flex items-center rounded-full border border-white/25 bg-black/30 backdrop-blur-sm px-5 py-1.5 text-[11px] font-semibold tracking-widest text-white/90 uppercase">
        Megnyitottunk!
      </span>
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-normal text-white leading-tight">
        Inárcsi Magánrendelő
      </h1>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-2xl">
        Inárcsi rendelőnk kialakításánál kiemelt figyelmet fordítottunk arra, hogy a gyermekek és családjuk is kellemes, nyugodt környezetben vehessék igénybe szolgáltatásainkat. Pácienseink számára többek között belgyógyászat, gyermekgyógyászat, arcüregátmosás, ABPM-vizsgálat, NLS állapotfelmérés, BEMER-terápia, nyirokmasszázs és energiamasszázs érhető el egy helyen.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a
          href="/idopontfoglalas"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white shadow-lg shadow-brand/30 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Időpontot foglalok →
        </a>
        <a
          href="#szolgaltatasok"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 text-white hover:bg-white/10 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Szolgáltatások
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-opacity="0.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <!-- ═══ GYERMEKGYÓGYÁSZAT ═══ -->
  <section id="szolgaltatasok" class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="flex flex-col gap-6">
          <span class="inline-flex w-fit items-center rounded-full bg-brand-50 border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
            Gyermekgyógyászat
          </span>
          <h2 class="text-3xl font-normal text-gray-900">A gyerek egészségére figyelünk – a legteljesebb értelemben</h2>
          <ul class="flex flex-col gap-4">
            {gyermekList.map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="/images/inarcs/gyermek-jatszosarok.jpg" alt="Gyermekjátszósarok – Lélekliget Inárcs" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FUNKCIONÁLIS BELGYÓGYÁSZAT ═══ -->
  <section class="bg-brand-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden order-2 lg:order-1">
          <img src="/images/inarcs/vizsgaloszoba.jpg" alt="Vizsgálószoba – Lélekliget Inárcs" class="w-full h-full object-cover" />
        </div>
        <div class="flex flex-col gap-6 order-1 lg:order-2">
          <span class="inline-flex w-fit items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
            Funkcionális belgyógyászat
          </span>
          <h2 class="text-3xl font-normal text-gray-900">A valódi okok nyomában – egészség tüneti kezelések nélkül</h2>
          <ul class="flex flex-col gap-4">
            {belgyList.map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ARCÜREGGYULLADÁS ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="flex flex-col gap-6">
          <span class="inline-flex w-fit items-center rounded-full bg-brand-50 border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
            Arcüreggyulladás
          </span>
          <h2 class="text-3xl font-normal text-gray-900">Arcüregi panaszok komplex kezelése</h2>
          <ul class="flex flex-col gap-4">
            {arcuregList.map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden">
          <img src="/images/inarcs/teknos-fuggony.jpg" alt="Arcüregátmosás – Lélekliget Inárcs" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ NLS DIAGNOSZTIKA ═══ -->
  <section class="bg-brand-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden order-2 lg:order-1">
          <img src="/images/inarcs/varo.jpg" alt="Váró – Lélekliget Inárcs" class="w-full h-full object-cover" />
        </div>
        <div class="flex flex-col gap-6 order-1 lg:order-2">
          <span class="inline-flex w-fit items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
            NLS technológia
          </span>
          <h2 class="text-3xl font-normal text-gray-900">Non-invazív, sejtszintű állapotfelmérés</h2>
          <ul class="flex flex-col gap-4">
            {nlsList.map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KIEGÉSZÍTŐ TERÁPIÁK ═══ -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-8">
      <h2 class="text-3xl font-normal text-gray-900">
        Kiegészítő terápiák
      </h2>
      <p class="text-gray-600 leading-relaxed">
        Inárcsi rendelőnkben a hagyományos és alternatív módszerek egyaránt elérhetők, támogatva a test öngyógyító folyamatait.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Masszázs', 'Akupunktúra', 'Energiagyógyászat', 'BEMER terápia', 'Esszenciális olajok', 'Családállítás', 'Csontkovács'].map(tag => (
          <span class="inline-flex items-center border border-brand text-brand text-sm font-medium px-5 py-2 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <a href="/idopontfoglalas" class="btn-outline text-sm px-7 py-2.5">
        Bejelentkezés előre egyeztetett időpontban
      </a>
    </div>
  </section>

  <!-- ═══ SZOLGÁLTATÁSOK KÁRTYÁK ═══ -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-normal text-gray-900 mb-3">Elérhető szolgáltatások</h2>
        <p class="text-gray-500 text-base">Mindezek az Inárcsi Magánrendelőben vehetők igénybe</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          {
            title: 'Funkcionális Gyermekgyógyászat',
            description: 'A várandósságtól kezdődően prevenciós tanácsadás, ellátás a legkisebbeknek, holisztikus szemléletű tanácsadás és terápia.',
            priceLabel: 'Konzultációs díj',
            price: '35 000',
            priceNote: 'Ft / 30 perc',
          },
          {
            title: 'Funkcionális Belgyógyászat',
            description: 'Teljes körű belgyógyászati vizsgálat, okfeltárás a gyökerektől, holisztikus kezelési terv az Ön egészsége érdekében.',
            priceLabel: 'Konzultációs díj',
            price: '35 000',
            priceNote: 'Ft / 30 perc',
          },
          {
            title: 'Kiegészítő terápiák',
            description: 'Masszázs, akupunktúra, energiagyógyászat, BEMER terápia, esszenciális olajok, családállítás, csontkovács.',
            priceLabel: 'Kezelési díj',
            price: '–',
            priceNote: '',
          },
        ].map((s) => (
          <a
            href="/szolgaltatasok"
            class="group flex flex-col gap-4 rounded-2xl border border-gray-100 bg-white p-7 hover:border-brand/30 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-lg font-normal text-black group-hover:text-brand transition-colors leading-snug">{s.title}</h3>
              <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-dark shrink-0 mt-0.5">Inárcs</span>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">{s.description}</p>
            <div class="mt-auto pt-4 border-t border-gray-100 flex items-end justify-between gap-2">
              <div class="flex flex-col gap-0.5">
                <span class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">{s.priceLabel}</span>
                <div class="flex items-baseline gap-1.5">
                  <span class="text-xl font-semibold text-brand leading-none">{s.price}</span>
                  {s.priceNote && <span class="text-sm text-gray-400">{s.priceNote}</span>}
                  {!s.priceNote && s.price === '–' && <span class="text-sm text-gray-400">Hamarosan</span>}
                </div>
              </div>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand shrink-0">
                Részletek
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <BookingCTA
    title="Foglaljon időpontot az inárcsi rendelőbe"
    description="Várjuk Önt és gyermekét természetközeli, barátságos környezetünkben. Ingyenes parkoló, könnyű megközelíthetőség az M5-ről."
  />

</BaseLayout>
