---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';
---

<BaseLayout
  title="Inárcsi Magánrendelő | Lélekliget"
  description="Gyermekgyógyászat, funkcionális orvoslás és holisztikus kiegészítő terápiák természetközeli környezetben, Inárcson."
>

  <!-- ═══ HERO ═══ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    style="background-image: url('https://images.unsplash.com/photo-1510797215324-95aa89f43c33?w=1920&q=80&fit=crop'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 flex flex-col items-center gap-7 max-w-3xl px-4 sm:px-6">
      <span class="inline-flex items-center rounded-full border border-white/25 bg-black/30 backdrop-blur-sm px-5 py-1.5 text-[11px] font-semibold tracking-widest text-white/90 uppercase">
        Hamarosan nyílik – 2026. május
      </span>
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-normal text-white leading-tight">
        Inárcsi Magánrendelő
      </h1>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-xl">
        Csendes, természetközeli környezetben, modern technológiával és szakértelemmel várjuk
        pácienseinket. Ahol a gyógyítás és a nyugalom találkozik.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a
          href="/idopontfoglalas"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white shadow-lg shadow-brand/30 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Időpontot foglalok →
        </a>
        <a
          href="#szolgaltatasok"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 text-white hover:bg-white/10 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Szolgáltatások
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-opacity="0.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <!-- ═══ GYERMEKGYÓGYÁSZAT ═══ -->
  <section id="szolgaltatasok" class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="flex flex-col gap-6">
          <h2 class="text-3xl font-normal text-gray-900">A gyerek egészségére figyelünk</h2>
          <p class="text-gray-600 leading-relaxed">
            Speciális gyermekgyógyászati ellátásunk során a legkisebbeknek test és lelki fejlődését
            kísérjük figyelemmel szakértő kezekben. Barátságos, otthonos környezetben, ahol a
            gyerekek is jól érzik magukat.
          </p>
          <ul class="flex flex-col gap-3">
            {[
              'Rendszeres csecsemő- és gyermekvizsgálatok',
              'Szakértő tanácsadás táplálkozás és fejlődés kérdéseiben',
              'Barátságos, stresszmenetes környezet a kicsiknek',
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FUNKCIONÁLIS ORVOSLÁS ═══ -->
  <section class="bg-brand-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative order-2 lg:order-1">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

        <div class="flex flex-col gap-6 order-1 lg:order-2">
          <h2 class="text-3xl font-normal text-gray-900">
            Amikor a szokásos vizsgálatok nem adnak választ
          </h2>
          <p class="text-gray-600 leading-relaxed">
            A funkcionális orvoslás az egyént egységként kezeli, keresve a tünetek mögötti
            meghatározó gyökérokokra és anyagcsere-folyamatokra. Részletes laborvizsgálatokkal
            és személyre szabott kezelési tervvel dolgozunk.
          </p>
          <div class="grid grid-cols-2 gap-3">
            {['Anyagcsere-analízis', 'Személyre szabott terv', 'Részletes laborvizsgálatok', 'Étrend-tanácsadás'].map(tag => (
              <span class="flex items-center justify-center text-center border border-brand/30 text-brand bg-white text-xs font-medium px-3 py-2.5 rounded-xl leading-tight">
                {tag}
              </span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ NLS DIAGNOSZTIKA ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="flex flex-col gap-6">
          <h2 class="text-3xl font-normal text-gray-900">
            Nem invazív diagnosztika a mélységekből
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Az NLS (Non-Lineáris Szisztéma) mérés lehetővé teszi a szervezet finom energetikai
            eltéréseinek feltérképezését fájdalommentesen. Korai jelzések, amelyek megelőzik a
            tünetek kialakulását.
          </p>
          <blockquote class="border-l-4 border-brand pl-5 py-2">
            <p class="text-gray-700 italic leading-relaxed text-sm">
              „A prevenció alapja a korai felismerés, ahol a technológia segít belátni a láthatatlamba."
            </p>
          </blockquote>
        </div>

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ KIEGÉSZÍTŐ TERÁPIÁK ═══ -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-8">
      <h2 class="text-3xl font-normal text-gray-900">
        Holisztikus szemléletű kiegészítő terápiák
      </h2>
      <p class="text-gray-600 leading-relaxed">
        Inárcsi rendelőnkben nemcsak tüneteket kezelünk, hanem támogatjuk a test öngyógyító
        folyamatát speciális wellness és energetikai kezelésekkel.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Fitoterápia', 'Stresszkezelés', 'Életmód-tanácsadás', 'Homeopátia'].map(tag => (
          <span class="inline-flex items-center border border-brand text-brand text-sm font-medium px-5 py-2 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <a href="/rolunk" class="btn-outline text-sm px-7 py-2.5">
        Ismerje meg módszereinket
      </a>
    </div>
  </section>

  <!-- ═══ SZOLGÁLTATÁSOK ═══ -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-normal text-gray-900 mb-3">Elérhető szolgáltatások</h2>
        <p class="text-gray-500 text-base">Mindezek az Inárcsi Magánrendelőben vehetők igénybe</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          {
            title: 'Gyermekgyógyászat',
            description: 'Átfogó ellátás a legkisebbeknek, a prevenciótól az akut betegségek szakszerű kezeléséig. Rendszeres szűrővizsgálatok és fejlődéskísérés.',
            priceLabel: 'Konzultációs díj',
            price: '18 000',
          },
          {
            title: 'Funkcionális orvoslás',
            description: 'A tünetek mögötti gyökérokokra fókuszálunk. Részletes laborvizsgálatok, anyagcsere-analízis és személyre szabott kezelési terv.',
            priceLabel: 'Konzultációs díj',
            price: '25 000',
          },
          {
            title: 'Kiegészítő terápiák',
            description: 'Fitoterápia, homeopátia, stresszkezelés és energetikai kezelések a test öngyógyító folyamatainak támogatásához.',
            priceLabel: 'Kezelési díj',
            price: '15 000',
          },
        ].map((s) => (
          <a
            href="/szolgaltatasok"
            class="group flex flex-col gap-4 rounded-2xl border border-gray-100 bg-white p-7 hover:border-brand/30 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-lg font-normal text-black group-hover:text-brand transition-colors leading-snug">{s.title}</h3>
              <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-dark shrink-0 mt-0.5">Inárcs</span>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">{s.description}</p>
            <div class="mt-auto pt-4 border-t border-gray-100 flex items-end justify-between gap-2">
              <div class="flex flex-col gap-0.5">
                <span class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">{s.priceLabel}</span>
                <div class="flex items-baseline gap-1.5">
                  <span class="text-xl font-semibold text-brand leading-none">{s.price}</span>
                  <span class="text-sm text-gray-400">Ft / alkalom</span>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand shrink-0">
                Részletek
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA NAPTÁRRAL ═══ -->
  <BookingCTA
    title="Foglaljon időpontot az inárcsi rendelőbe"
    description="Válassza ki az Önnek megfelelő időpontot, vagy hívja asszisztensünket. Örömmel várjuk Önt és gyermekét."
  />

</BaseLayout>
