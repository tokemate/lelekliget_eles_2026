---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';
---

<BaseLayout
  title="Inárcsi Magánrendelő | Lélekliget"
  description="Gyermekgyógyászat, funkcionális orvoslás és holisztikus kiegészítő terápiák természetközeli környezetben, Inárcson."
>

  <!-- ═══ HERO ═══ -->
  <section class="relative bg-white overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 opacity-[0.04] pointer-events-none"
      style="background-image: radial-gradient(circle at 30% 50%, #41bdc4 0%, transparent 60%)"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <div class="flex flex-col gap-6">
          <span class="inline-flex w-fit items-center rounded-full border border-brand/40 bg-brand-50 px-4 py-1 text-xs font-medium text-brand-dark">
            Hamarosan nyílik – 2026. május
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-normal text-black leading-tight">
            Inárcsi Magánrendelő
          </h1>
          <p class="text-base sm:text-lg text-gray-600 leading-relaxed max-w-lg">
            Csendes, természetközeli környezetben, modern technológiával és szakértelemmel várjuk
            pácienseinket. Ahol a gyógyítás és a nyugalom találkozik.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href="/idopontfoglalas" class="btn-brand text-base px-8 py-3">
              Időpontot foglalok
            </a>
            <a href="#szolgaltatasok" class="btn-outline text-base px-8 py-3">
              Szolgáltatások
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden bg-brand-light flex items-center justify-center relative">
            <div class="absolute inset-0 bg-gradient-to-br from-brand/20 to-brand/5"></div>
            <div class="relative text-center p-8">
              <div class="mx-auto mb-3 w-14 h-14 rounded-full bg-brand/20 flex items-center justify-center">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <p class="text-sm text-brand-dark font-medium">Rendelő fotó hamarosan</p>
              <p class="text-xs text-gray-400 mt-1">2345 Inárcs, Liget utca 12.</p>
            </div>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg p-4 flex items-center gap-3 border border-gray-100">
            <div class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-black">Gyermekgyógyászat</p>
              <p class="text-xs text-gray-500">Holisztikus szemlélettel</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ GYERMEKGYÓGYÁSZAT ═══ -->
  <section id="szolgaltatasok" class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="flex flex-col gap-6">
          <h2 class="text-3xl font-normal text-gray-900">A gyerek egészségére figyelünk</h2>
          <p class="text-gray-600 leading-relaxed">
            Speciális gyermekgyógyászati ellátásunk során a legkisebbeknek test és lelki fejlődését
            kísérjük figyelemmel szakértő kezekben. Barátságos, otthonos környezetben, ahol a
            gyerekek is jól érzik magukat.
          </p>
          <ul class="flex flex-col gap-3">
            {[
              'Rendszeres csecsemő- és gyermekvizsgálatok',
              'Szakértő tanácsadás táplálkozás és fejlődés kérdéseiben',
              'Barátságos, stresszmenetes környezet a kicsiknek',
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-5 h-5 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-gray-700 text-sm leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FUNKCIONÁLIS ORVOSLÁS ═══ -->
  <section class="bg-brand-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative order-2 lg:order-1">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

        <div class="flex flex-col gap-6 order-1 lg:order-2">
          <h2 class="text-3xl font-normal text-gray-900">
            Amikor a szokásos vizsgálatok nem adnak választ
          </h2>
          <p class="text-gray-600 leading-relaxed">
            A funkcionális orvoslás az egyént egységként kezeli, keresve a tünetek mögötti
            meghatározó gyökérokokra és anyagcsere-folyamatokra. Részletes laborvizsgálatokkal
            és személyre szabott kezelési tervvel dolgozunk.
          </p>
          <div class="grid grid-cols-2 gap-3">
            {['Anyagcsere-analízis', 'Személyre szabott terv', 'Részletes laborvizsgálatok', 'Étrend-tanácsadás'].map(tag => (
              <span class="flex items-center justify-center text-center border border-brand/30 text-brand bg-white text-xs font-medium px-3 py-2.5 rounded-xl leading-tight">
                {tag}
              </span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ NLS DIAGNOSZTIKA ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="flex flex-col gap-6">
          <h2 class="text-3xl font-normal text-gray-900">
            Nem invazív diagnosztika a mélységekből
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Az NLS (Non-Lineáris Szisztéma) mérés lehetővé teszi a szervezet finom energetikai
            eltéréseinek feltérképezését fájdalommentesen. Korai jelzések, amelyek megelőzik a
            tünetek kialakulását.
          </p>
          <blockquote class="border-l-4 border-brand pl-5 py-2">
            <p class="text-gray-700 italic leading-relaxed text-sm">
              „A prevenció alapja a korai felismerés, ahol a technológia segít belátni a láthatatlamba."
            </p>
          </blockquote>
        </div>

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ KIEGÉSZÍTŐ TERÁPIÁK ═══ -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-8">
      <h2 class="text-3xl font-normal text-gray-900">
        Holisztikus szemléletű kiegészítő terápiák
      </h2>
      <p class="text-gray-600 leading-relaxed">
        Inárcsi rendelőnkben nemcsak tüneteket kezelünk, hanem támogatjuk a test öngyógyító
        folyamatát speciális wellness és energetikai kezelésekkel.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Fitoterápia', 'Stresszkezelés', 'Életmód-tanácsadás', 'Homeopátia'].map(tag => (
          <span class="inline-flex items-center border border-brand text-brand text-sm font-medium px-5 py-2 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <a href="/kapcsolat" class="btn-outline text-sm px-7 py-2.5">
        Ismerje meg módszereinket
      </a>
    </div>
  </section>

  <!-- ═══ CTA NAPTÁRRAL ═══ -->
  <BookingCTA
    title="Foglaljon időpontot az inárcsi rendelőbe"
    description="Válassza ki az Önnek megfelelő időpontot, vagy hívja asszisztensünket. Örömmel várjuk Önt és gyermekét."
  />

</BaseLayout>
