---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';

const terapiak = [
  'Masszázs',
  'Akupunktúra',
  'Energiagyógyászat',
  'BEMER terápia',
  'Esszenciális olajok',
  'Családállítás',
  'Csontkovács',
];
---

<BaseLayout
  title="Kiegészítő Terápiák | Lélekliget"
  description="Masszázs, akupunktúra, energiagyógyászat, BEMER terápia, esszenciális olajok, családállítás, csontkovács – a test öngyógyító folyamatainak támogatásához. Dabas és Inárcs."
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl flex flex-col items-center gap-5">
      <div class="flex items-center gap-2 flex-wrap justify-center">
        <span class="inline-flex items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-medium text-brand-dark">
          Dabas & Inárcs
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900">
        Kiegészítő terápiák
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-xl">
        A hagyományos és alternatív módszerek egyaránt elérhetők rendelőinkben, támogatva a test öngyógyító folyamatait.
      </p>
      <a
        href="/idopontfoglalas"
        class="inline-flex items-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white px-8 py-3 text-sm font-semibold transition-colors shadow-md shadow-brand/20"
      >
        Időpontot foglalok →
      </a>
    </div>
  </section>

  <!-- ═══ TARTALOM ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto flex flex-col gap-10">
      <div class="flex flex-col gap-4">
        <span class="inline-flex w-fit items-center rounded-full bg-brand-50 border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
          Kiegészítő terápiák
        </span>
        <h2 class="text-3xl font-normal text-gray-900">
          Elérhető kezelések
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Inárcsi és dabasi rendelőinkben a hagyományos és alternatív módszerek egyaránt elérhetők, támogatva a test öngyógyító folyamatait.
        </p>
      </div>

      <!-- Terápia tagek -->
      <div class="flex flex-wrap gap-3">
        {terapiak.map(t => (
          <span class="inline-flex items-center border border-brand text-brand text-sm font-medium px-5 py-2.5 rounded-full">
            {t}
          </span>
        ))}
      </div>

      <!-- Munkatársaink -->
      <div class="bg-brand-50 rounded-2xl p-8 flex flex-col gap-4 border border-brand/10">
        <h3 class="text-lg font-medium text-gray-900">Szakembereink</h3>
        <div class="flex flex-col gap-3">
          <div class="flex flex-col gap-0.5">
            <p class="text-sm font-semibold text-gray-800">Petrányi Zsoltné Ildikó</p>
            <p class="text-xs text-gray-500">Masszőr – energetikai, talp- és nyirokmasszázs, thai masszázs</p>
          </div>
          <div class="flex flex-col gap-0.5">
            <p class="text-sm font-semibold text-gray-800">Udvardi Zsuzsanna</p>
            <p class="text-xs text-gray-500">Természetgyógyász, fülakupunktúrás addiktológus – fülakupunktúra, doTERRA AromaTouch™ terápia</p>
          </div>
        </div>
        <a href="/rolunk" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand hover:text-brand-dark transition-colors mt-1">
          Ismerje meg csapatunkat →
        </a>
      </div>

      <!-- Helyszínek -->
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          { name: 'Lélekliget Gyógycentrum – Inárcs magánrendelés', address: '2365 Inárcs, Kastély u. 4.' },
          { name: 'Lélekliget Dabas', address: '2370 Dabas, Vörösmarty u. 3. emelet' },
        ].map(loc => (
          <div class="bg-white rounded-2xl p-6 flex flex-col gap-2 border border-gray-100">
            <div class="flex items-start gap-2 text-gray-700">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <div>
                <p class="font-medium text-sm">{loc.name}</p>
                <p class="text-xs text-gray-500 mt-0.5">{loc.address}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- doTERRA -->
  <section class="py-10 px-4">
    <div class="mx-auto max-w-3xl">
      <div class="bg-brand-light rounded-2xl px-8 py-14 text-center flex flex-col items-center gap-6">
        <p class="text-xs font-semibold tracking-widest text-brand-dark uppercase">
          Természetes megoldások a mindennapi élethez
        </p>
        <h2 class="text-3xl font-normal text-gray-900">Természetes megoldások a mindennapi élethez</h2>
        <p class="text-gray-700 leading-relaxed max-w-xl">
          Rendelőnk kiemelt partnere a doTERRA, a világ vezető illóolaj-gyártója. Hiszünk abban,
          hogy a természet ereje hatékony kiegészítője lehet a gyógyulási folyamatnak és a
          megelőzésnek egyaránt. Ismerje meg tiszta, terápiás minőségű megoldásainkat.
        </p>
        <a
          href="#"
          class="inline-flex items-center rounded-full border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white px-6 py-2 text-sm font-medium transition-colors"
        >
          Tovább a doTERRA oldalra →
        </a>
      </div>
    </div>
  </section>

  <!-- BEMER -->
  <section class="pb-10 px-4">
    <div class="mx-auto max-w-3xl">
      <div class="bg-brand-light rounded-2xl px-8 py-14 text-center flex flex-col items-center gap-6">
        <p class="text-xs font-semibold tracking-widest text-brand-dark uppercase">
          Mikrocirkuláció & sejt szintű regeneráció
        </p>
        <h2 class="text-3xl font-normal text-gray-900">A BEMER terápia ereje</h2>
        <p class="text-gray-700 leading-relaxed max-w-xl">
          Rendelőnk hivatalos BEMER kezelőhely. A készülék a fizikai érterápia egyedüli,
          világszintű vezető márkája. A BEMER-készülékek egyedülálló jelformájukkal támogatják
          a szervezet természetes öngyógyító folyamatait, javítják a vérkeringést és elősegítik
          a regenerációt. Ismerje meg innovatív megoldásainkat.
        </p>
        <a
          href="https://accomed.bemergroup.com/hu_HU/human-line/kezdolap"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white px-6 py-2 text-sm font-medium transition-colors"
        >
          Tovább a BEMER oldalra →
        </a>
      </div>
    </div>
  </section>

  <BookingCTA
    title="Foglaljon kiegészítő kezelést"
    description="AromaTouch masszázs, nyirokmasszázs, energiagyógyászat, csontkovácsolás, családállítás, ingás közvetítés, hangtál, fülakupunktúra – a test és a lélek harmóniájáért."
  />

</BaseLayout>
