---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';
---

<BaseLayout
  title="NLS Teljes Test Állapotfelmérés | Lélekliget"
  description="Az NLS-rendszer egy számítógéppel támogatott állapotfelmérő módszer, amely a szervezet működéséről nyújt információkat. Korai felismerés fájdalom nélkül."
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl flex flex-col items-center gap-5">
      <div class="flex items-center gap-2 flex-wrap justify-center">
        <span class="inline-flex items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-medium text-brand-dark">
          Dabas & Inárcs
        </span>
        <span class="inline-flex items-center rounded-full bg-brand-light border border-brand/20 px-3 py-1 text-xs font-semibold text-brand-dark">
          45 000 Ft / 90 perc
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900">
        NLS Teljes Test Állapotfelmérés
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-xl">
        Számítógéppel támogatott állapotfelmérő módszer, amely a szervezet működéséről nyújt átfogó információkat – korai felismerés, fájdalommentesen.
      </p>
      <a
        href="/idopontfoglalas"
        class="inline-flex items-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white px-8 py-3 text-sm font-semibold transition-colors shadow-md shadow-brand/20"
      >
        Időpontot foglalok →
      </a>
    </div>
  </section>

  <!-- ═══ TARTALOM ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto flex flex-col gap-10">
      <div class="flex flex-col gap-4">
        <span class="inline-flex w-fit items-center rounded-full bg-brand-50 border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
          NLS technológia
        </span>
        <h2 class="text-3xl font-normal text-gray-900">
          Non-invazív, sejtszintű állapotfelmérés
        </h2>
      </div>
      <div class="w-full rounded-2xl overflow-hidden">
        <img src="/images/inarcs/nls-meres.jpg" alt="NLS mérés – Lélekliget" class="w-full h-auto object-cover" />
      </div>
      <div class="prose max-w-none prose-p:text-gray-600 prose-p:leading-relaxed prose-strong:text-gray-800 prose-headings:font-heading prose-headings:font-normal prose-headings:text-gray-900">
        <p>
          Az NLS-rendszer egy számítógéppel támogatott állapotfelmérő módszer, amely a szervezet
          működéséről nyújt információkat. A vizsgálat során a rendszer speciális érzékelők
          segítségével gyűjt adatokat, amelyeket számítógépes elemzéssel értékel. Az
          állapotfelmérés célja, hogy átfogó képet adjon a szervezet működéséről, segítsen az
          esetleges eltérések, terhelések és kockázati tényezők felismerésében, valamint
          támogassa az egészségtudatos életmód kialakítását.
        </p>
        <p>
          A rendszer lehetőséget biztosít különböző szervek és szervrendszerek működésének
          összehasonlító elemzésére, valamint egyes környezeti, táplálkozási vagy életmódbeli
          tényezők szervezetre gyakorolt hatásának vizsgálatára. Az eredmények alapján
          személyre szabott javaslatok fogalmazhatók meg az életmód, a táplálkozás és az
          általános egészségmegőrzés támogatására.
        </p>
        <p>
          Az NLS-vizsgálat nem helyettesíti az orvosi diagnózist, a szakorvosi vizsgálatot vagy
          a laboratóriumi és képalkotó diagnosztikai módszereket, hanem az egészségi állapot
          komplex felmérésének kiegészítő eszközeként alkalmazható.
        </p>
      </div>

      <!-- Helyszín kártyák -->
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          { name: 'Lélekliget Gyógycentrum – Inárcs magánrendelés', address: '2365 Inárcs, Kastély u. 4.' },
          { name: 'Lélekliget Dabas', address: '2370 Dabas, Vörösmarty u. 3. emelet' },
        ].map(loc => (
          <div class="bg-brand-50 rounded-2xl p-6 flex flex-col gap-2 border border-brand/10">
            <div class="flex items-start gap-2 text-gray-700">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <div>
                <p class="font-medium text-sm">{loc.name}</p>
                <p class="text-xs text-gray-500 mt-0.5">{loc.address}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <BookingCTA
    title="Foglaljon NLS vizsgálatot"
    description="Modern, non-invazív teljes test állapotfelmérés a szervezet információs mezőinek elemzésével. Elérhető mindkét helyszínünkön."
  />

</BaseLayout>
