---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';

const specialAreas = [
  { label: 'Ételintoleranciák', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>` },
  { label: 'Anyagcsere-zavarok', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>` },
  { label: 'Hormonális egyensúly', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>` },
  { label: 'Sporttáplálkozás', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>` },
];

const steps = [
  { n: '1', title: 'Első konzultáció', desc: 'Alapos anamnézis felvételés és életmódbeli szokások áttekintése.' },
  { n: '2', title: 'Étrendi terv', desc: 'Az NLS eredmények és az Ön célja alapján összeállított, fenntartható táplálkozási útmutató.' },
  { n: '3', title: 'Nyomon követés', desc: 'Rendszeres kontrollok finomhangolás az optimális eredmények eléréséhez.' },
];
---

<BaseLayout
  title="Dabasi Gyógycentrum | Lélekliget"
  description="NLS diagnosztika és személyre szabott étrend-tanácsadás Dabas szívében. Nem invazív, modern megközelítés az Ön egészségéért."
>

  <!-- ═══ HERO ═══ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    style="background-image: url('https://images.unsplash.com/photo-1511497584788-876760111969?w=1920&q=80&fit=crop'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 flex flex-col items-center gap-7 max-w-3xl px-4 sm:px-6">
      <span class="inline-flex items-center rounded-full border border-white/25 bg-black/30 backdrop-blur-sm px-5 py-1.5 text-[11px] font-semibold tracking-widest text-white/90 uppercase">
        Dabasi Gyógycentrum
      </span>
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-normal text-white leading-tight">
        Dabasi Gyógycentrum<br class="hidden sm:block" /> – közel Önhöz
      </h1>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-xl">
        Exkluzív környezetű dabasi rendelőnkben a feltöltődés és a harmónia kerül a középpontba. Az NLS állapotfelmérés és a BEMER-terápia mellett családállítás, masszázsok, illóolajok és hangtálas relaxációs programok segítik a testi-lelki jóllétet.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a
          href="/idopontfoglalas"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white shadow-lg shadow-brand/30 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Konzultáció kérése →
        </a>
        <a
          href="#szolgaltatasok"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 text-white hover:bg-white/10 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
        >
          Részletek
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-opacity="0.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <!-- ═══ NLS DIAGNOSZTIKA ═══ -->
  <section id="szolgaltatasok" class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div class="w-full aspect-[4/3] bg-brand-light rounded-2xl flex items-center justify-center relative order-2 lg:order-1">
          <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
          <span class="relative text-sm text-brand-dark font-medium">Fotó hamarosan</span>
        </div>

        <div class="flex flex-col gap-6 order-1 lg:order-2">
          <h2 class="text-3xl font-normal text-gray-900">Nem invazív diagnosztika</h2>
          <p class="text-gray-600 leading-relaxed">
            Az NLS (Non-Linear System) mérés korszerű, fájdalommentes technológia, amely lehetővé
            teszi a szervezet funkcionális állapotának feltérképezését. Segítségével még azelőtt
            felismerjük az egyensúlytalanságokat, hogy azok fizikai tünetekké válnának.
          </p>
          <div class="grid grid-cols-2 gap-3">
            {[
              { label: 'Gyors és pontos', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>` },
              { label: 'Fájdalommentes', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>` },
              { label: 'Személyre szabott', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>` },
              { label: 'Részletes elemzés', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>` },
            ].map(item => (
              <div class="flex items-center gap-2.5 bg-brand-50 rounded-xl px-4 py-3">
                <span class="text-brand shrink-0" set:html={item.icon} />
                <span class="text-sm font-medium text-gray-800">{item.label}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ ÉTREND-TANÁCSADÁS ═══ -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-normal text-gray-900 text-center mb-12">
        Az étrend, ami megváltoztatja az életet
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">

        <!-- Folyamatunk -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <h3 class="text-lg font-medium text-gray-900 mb-6">Folyamatunk</h3>
          <blockquote class="border-l-4 border-brand pl-4 mb-6">
            <p class="text-sm text-gray-600 italic leading-relaxed">
              „A táplálkozás nem csupán kalóriák bevitele, hanem a gyógyulás első lépése."
            </p>
          </blockquote>
          <div class="flex flex-col gap-5">
            {steps.map(step => (
              <div class="flex gap-4 items-start">
                <span class="shrink-0 w-8 h-8 rounded-full bg-brand text-white text-sm font-semibold flex items-center justify-center">
                  {step.n}
                </span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 mb-0.5">{step.title}</p>
                  <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Speciális területek -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Speciális területek</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-6">
            Tanácsadásunk során különös figyelmet fordítunk az alábbi speciális állapotokra,
            biztosítva a legmagasabb szintű szakmai támogatást.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {specialAreas.map(area => (
              <div class="flex flex-col items-start gap-2.5 rounded-xl border border-gray-100 p-4 hover:border-brand/30 hover:shadow-sm transition-all">
                <div class="w-10 h-10 rounded-lg bg-brand-light flex items-center justify-center text-brand" set:html={area.icon} />
                <span class="text-sm font-medium text-gray-800 leading-tight">{area.label}</span>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Nagy kép placeholder -->
      <div class="w-full h-56 bg-brand-light rounded-2xl flex items-center justify-center relative">
        <div class="absolute inset-0 bg-gradient-to-br from-brand/10 to-transparent rounded-2xl"></div>
        <span class="relative text-sm text-brand-dark font-medium">Rendelő fotó hamarosan</span>
      </div>

    </div>
  </section>

  <!-- ═══ SZOLGÁLTATÁSOK ═══ -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-normal text-gray-900 mb-3">Elérhető szolgáltatások</h2>
        <p class="text-gray-500 text-base">Mindezek a Dabasi Gyógycentrumban vehetők igénybe</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          {
            title: 'NLS diagnosztika',
            description: 'Non-invazív energetikai állapotfelmérés a szervezet információs mezőinek elemzésével. Korai felismerés fájdalom nélkül.',
            priceLabel: 'Vizsgálati díj',
            price: '32 000',
          },
          {
            title: 'Étrend-tanácsadás',
            description: 'Személyre szabott táplálkozási terv az életmódváltáshoz. Funkcionális szemlélet, amely figyelembe veszi az egyéni biokémiai sajátosságokat.',
            priceLabel: 'Konzultációs díj',
            price: '20 000',
          },
          {
            title: 'Kiegészítő terápiák',
            description: 'Fitoterápia, homeopátia, stresszkezelés és energetikai kezelések a test öngyógyító folyamatainak támogatásához.',
            priceLabel: 'Kezelési díj',
            price: '15 000',
          },
        ].map((s) => (
          <a
            href="/szolgaltatasok"
            class="group flex flex-col gap-4 rounded-2xl border border-gray-100 bg-white p-7 hover:border-brand/30 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-lg font-normal text-black group-hover:text-brand transition-colors leading-snug">{s.title}</h3>
              <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-dark shrink-0 mt-0.5">Dabas</span>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">{s.description}</p>
            <div class="mt-auto pt-4 border-t border-gray-100 flex items-end justify-between gap-2">
              <div class="flex flex-col gap-0.5">
                <span class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">{s.priceLabel}</span>
                <div class="flex items-baseline gap-1.5">
                  <span class="text-xl font-semibold text-brand leading-none">{s.price}</span>
                  <span class="text-sm text-gray-400">Ft / alkalom</span>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand shrink-0">
                Részletek
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA NAPTÁRRAL ═══ -->
  <BookingCTA
    title="Foglaljon időpontot Dabasban"
    description="Várjuk szívesen a Dabasi Gyógycentrumban, ahol szakértőink segítenek Önnek az egészségesebb életmód kialakításában."
  />

</BaseLayout>
