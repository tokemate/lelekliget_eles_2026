---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/ui/BookingCTA.astro';

const items = [
  'Rendszeres csecsemő- és gyermekvizsgálatok: az egyéni fejlődési ritmust és a megelőzést előtérbe helyező szűrések.',
  'Személyre szabott életmód-tanácsadás: szakértő támogatás a táplálkozás, a mozgás és a lelki fejlődés kérdéseiben.',
  'Családközpontú szemlélet: partneri együttműködés és tanácsadás a szülőknek a mindennapok harmóniájáért.',
  'Barátságos, stresszmentes környezet: ahol a kicsik biztonságban és otthonosan érezhetik magukat.',
];
---

<BaseLayout
  title="Funkcionális Gyermekgyógyászat | Lélekliget"
  description="A várandósságtól kezdődően prevenciós tanácsadás, holisztikus szemléletű ellátás a legkisebbeknek. Rendszeres szűrővizsgálatok, személyre szabott tanácsadás és terápia Inárcson."
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-brand-50 py-20 px-4 text-center">
    <div class="mx-auto max-w-2xl flex flex-col items-center gap-5">
      <div class="flex items-center gap-2 flex-wrap justify-center">
        <span class="inline-flex items-center rounded-full bg-white border border-brand/20 px-3 py-1 text-xs font-medium text-brand-dark">
          Inárcs
        </span>
        <span class="inline-flex items-center rounded-full bg-brand-light border border-brand/20 px-3 py-1 text-xs font-semibold text-brand-dark">
          35 000 Ft / 30 perc
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900">
        Funkcionális Gyermekgyógyászat
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-xl">
        A várandósságtól kezdődően prevenciós tanácsadás a korai megelőzésért, ellátás a legkisebbeknek, a megelőzéstől az akut betegségek szakszerű kezeléséig. Rendszeres szűrővizsgálatok, holisztikus szemléletű tanácsadás és terápia.
      </p>
      <a
        href="/idopontfoglalas"
        class="inline-flex items-center gap-2 rounded-full bg-brand hover:bg-brand-dark text-white px-8 py-3 text-sm font-semibold transition-colors shadow-md shadow-brand/20"
      >
        Időpontot foglalok →
      </a>
    </div>
  </section>

  <!-- ═══ TARTALOM ═══ -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto flex flex-col gap-10">
      <div class="flex flex-col gap-4">
        <span class="inline-flex w-fit items-center rounded-full bg-brand-50 border border-brand/20 px-3 py-1 text-xs font-semibold tracking-widest uppercase text-brand-dark">
          Gyermekgyógyászat
        </span>
        <h2 class="text-3xl font-normal text-gray-900">
          A gyerek egészségére figyelünk – a legteljesebb értelemben
        </h2>
      </div>
      <ul class="flex flex-col gap-5">
        {items.map(item => (
          <li class="flex items-start gap-4">
            <span class="shrink-0 w-6 h-6 rounded-full bg-brand-light flex items-center justify-center mt-0.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class="text-gray-700 leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>

      <!-- Helyszín kártya -->
      <div class="bg-brand-50 rounded-2xl p-8 flex flex-col gap-3 border border-brand/10">
        <h3 class="text-lg font-medium text-gray-900">Helyszín</h3>
        <div class="flex items-start gap-2 text-gray-700">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <p class="font-medium">Lélekliget Gyógycentrum – Inárcs magánrendelés</p>
            <p class="text-sm text-gray-500">2365 Inárcs, Kastély u. 4. · Előzetes telefonos időpont egyeztetés szükséges.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <BookingCTA
    title="Foglaljon időpontot a gyermekgyógyászatra"
    description="Holisztikus szemléletű ellátás a legkisebbeknek és a várandós édesanyáknak, Inárcson. Ingyenes parkoló, könnyű megközelíthetőség az M5-ről."
  />

</BaseLayout>
