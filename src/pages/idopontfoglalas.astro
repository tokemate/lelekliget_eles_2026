---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Időpontfoglalás | Lélekliget Gyógycentrum"
  description="Foglaljon online időpontot a Lélekliget Gyógycentrum inárcsi vagy dabasi rendelőjébe."
>
  <section class="bg-brand-50 py-16 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-4">Időpontfoglalás</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Válassza ki a helyszínt és a kívánt időpontot az alábbi foglalórendszeren keresztül.
      </p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="mx-auto max-w-5xl">

      <!-- SimplyBook.me widget -->
      <div class="rounded-2xl overflow-hidden border border-gray-200 bg-white">
        <script src="//widget.simplybook.it/v2/widget/widget.js" type="text/javascript"></script>
        <script type="text/javascript" is:inline>
          var widget = new SimplybookWidget({"widget_type":"iframe","url":"https:\/\/lelekligetdabas.simplybook.it","theme":"default","theme_settings":{"timeline_hide_unavailable":"1","hide_past_days":"0","timeline_show_end_time":"0","timeline_modern_display":"as_slots","sb_base_color":"#c54b46","display_item_mode":"block","booking_nav_bg_color":"#c54b46","body_bg_color":"#f2f2f2","sb_review_image":"","dark_font_color":"#311919","light_font_color":"#f5fcff","btn_color_1":"#e45f59","sb_company_label_color":"#ffffff","hide_img_mode":"1","show_sidebar":"1","sb_busy":"#c7b3b3","sb_available":"#e2eaec"},"timeline":"modern","datepicker":"top_calendar","is_rtl":false,"app_config":{"clear_session":0,"allow_switch_to_ada":0,"predefined":[]}});
        </script>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-gray-100 bg-white p-6 flex flex-col gap-3">
          <h3 class="text-lg font-normal text-black">Inárcsi Magánrendelő</h3>
          <p class="text-sm text-gray-500">2365 Inárcs, Kastély u. 4.</p>
          <p class="text-sm text-gray-500">Előzetes telefonos időpont egyeztetés szükséges.</p>
          <a href="/szolgaltatasok/inarcs" class="text-sm font-medium text-brand hover:text-brand-dark transition-colors">
            Szolgáltatások →
          </a>
        </div>
        <div class="rounded-2xl border border-gray-100 bg-white p-6 flex flex-col gap-3">
          <h3 class="text-lg font-normal text-black">Dabasi Gyógycentrum</h3>
          <p class="text-sm text-gray-500">2370 Dabas, Vörösmarty u. 3. emelet</p>
          <p class="text-sm text-gray-500">Előzetes telefonos időpont egyeztetés szükséges.</p>
          <a href="/szolgaltatasok/dabas" class="text-sm font-medium text-brand hover:text-brand-dark transition-colors">
            Szolgáltatások →
          </a>
        </div>
      </div>

      <div class="mt-6 grid sm:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-gray-100 bg-white p-6 flex flex-col gap-2">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Email</h3>
          <a href="mailto:praxis@lelekligetdabas.hu" class="text-brand hover:underline">praxis@lelekligetdabas.hu</a>
        </div>
        <div class="rounded-2xl border border-gray-100 bg-white p-6 flex flex-col gap-2">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Telefon</h3>
          <a href="tel:+36301789543" class="text-brand hover:underline">+36 30 1 789 543</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
