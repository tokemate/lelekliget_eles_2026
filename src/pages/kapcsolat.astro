---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⚠️  Cseréld ki a saját Web3Forms access key-edre!
// Ingyenes kulcs: https://web3forms.com  (email cím megadásával azonnal megkapod)
const WEB3FORMS_KEY = 'CSERÉLD_KI_A_WEB3FORMS_ACCESS_KEY-RE';
---

<BaseLayout
  title="Kapcsolat | Lélekliget Gyógycentrum"
  description="Vegye fel velünk a kapcsolatot. Elérhetőségeink, helyszíneink és kapcsolati űrlapunk."
>
  <section class="bg-brand-50 py-16 px-4 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-normal text-gray-900 mb-4">Kapcsolat</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Kérdése van? Örömmel segítünk. Írjon nekünk vagy hívjon minket.
      </p>
    </div>
  </section>

  <section id="uzenjen" class="py-16 px-4">
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Elérhetőségek -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-2xl font-normal text-gray-900 mb-6">Elérhetőségeink</h2>
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Inárcs</h3>
              <p class="text-gray-700">2365 Inárcs, Kastély u. 4.</p>
              <p class="text-gray-600 text-sm">Előzetes telefonos időpont egyeztetés szükséges.</p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Dabas</h3>
              <p class="text-gray-700">2370 Dabas, Vörösmarty u. 3. emelet</p>
              <p class="text-gray-600 text-sm">Előzetes telefonos időpont egyeztetés szükséges.</p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Email</h3>
              <a href="mailto:praxis@lelekligetdabas.hu" class="text-brand hover:underline">praxis@lelekligetdabas.hu</a>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Telefon</h3>
              <a href="tel:+36301789543" class="text-brand hover:underline">+36 30 1 789 543</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Kapcsolati form -->
      <div>
        <h2 class="text-2xl font-normal text-gray-900 mb-6">Írjon nekünk</h2>

        <!-- Sikeres beküldés üzenet (alapból rejtett) -->
        <div id="form-success" class="hidden rounded-2xl bg-brand-50 border border-brand/20 p-8 text-center flex flex-col items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-brand/10 flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#41bdc4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3 class="text-xl font-normal text-gray-900">Üzenet elküldve!</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Köszönjük megkeresését. Munkatársunk hamarosan felveszi Önnel a kapcsolatot.
          </p>
        </div>

        <!-- Hibaüzenet (alapból rejtett) -->
        <div id="form-error" class="hidden rounded-2xl bg-red-50 border border-red-200 p-4 text-sm text-red-700 mb-4">
          Hiba történt a küldés során. Kérjük, próbálja újra, vagy írjon közvetlenül az
          <a href="mailto:praxis@lelekligetdabas.hu" class="underline">praxis@lelekligetdabas.hu</a> címre.
        </div>

        <form id="contact-form" class="flex flex-col gap-4">
          <!-- Web3Forms kötelező mezők -->
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Új üzenet — Lélekliget kapcsolati form" />
          <input type="hidden" name="from_name" value="Lélekliget Weboldal" />
          <!-- Spam védelem -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-sm font-medium text-gray-700">Neve</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              placeholder="Kovács Anna"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-gray-700">Email cím</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              placeholder="anna@example.hu"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="phone" class="text-sm font-medium text-gray-700">
              Telefonszám <span class="text-gray-400 font-normal">(nem kötelező)</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              placeholder="+36 30 123 4567"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-medium text-gray-700">Üzenet</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand resize-none"
              placeholder="Írja ide kérdését…"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="btn-brand w-full justify-center"
          >
            <span id="btn-text">Üzenet küldése</span>
            <svg id="btn-spinner" class="hidden animate-spin ml-2" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-opacity="0.25"/>
              <path d="M21 12a9 9 0 00-9-9"/>
            </svg>
          </button>

          <p class="text-xs text-gray-400 text-center">
            Az adatait bizalmasan kezeljük.
            <a href="/adatkezeles" class="text-brand hover:underline">Adatkezelési tájékoztató</a>
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Töltés állapot
    submitBtn.disabled = true;
    btnText!.textContent = 'Küldés…';
    btnSpinner?.classList.remove('hidden');
    errorBox?.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });

      const json = await res.json();

      if (res.ok && json.success) {
        form.classList.add('hidden');
        successBox?.classList.remove('hidden');
      } else {
        throw new Error(json.message || 'Ismeretlen hiba');
      }
    } catch {
      errorBox?.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText!.textContent = 'Üzenet küldése';
      btnSpinner?.classList.add('hidden');
    }
  });
</script>
