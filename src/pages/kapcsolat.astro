---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kapcsolat | Lélekliget Gyógycentrum"
  description="Vegye fel velünk a kapcsolatot. Elérhetőségeink, helyszíneink és kapcsolati űrlapunk."
>
  <section
    class="relative min-h-[70vh] flex flex-col items-center justify-center text-center overflow-hidden"
    style="background-image: url('https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=1920&q=80&fit=crop'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 flex flex-col items-center gap-6 max-w-2xl px-4 sm:px-6">
      <span class="inline-flex items-center rounded-full border border-white/25 bg-black/30 backdrop-blur-sm px-5 py-1.5 text-[11px] font-semibold tracking-widest text-white/90 uppercase">
        Lépjen kapcsolatba velünk
      </span>
      <h1 class="font-heading text-5xl sm:text-6xl font-normal text-white leading-tight">
        Kapcsolat
      </h1>
      <p class="text-base sm:text-lg text-white/70 leading-relaxed">
        Kérdése van? Örömmel segítünk. Írjon nekünk vagy hívjon minket.
      </p>
      <a
        href="#uzenjen"
        class="mt-2 inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 backdrop-blur-sm text-white hover:bg-white/25 px-8 py-3.5 text-sm font-semibold tracking-wide transition-colors"
      >
        Írjon nekünk →
      </a>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-opacity="0.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <section id="uzenjen" class="py-16 px-4">
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Elérhetőségek -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-2xl font-normal text-gray-900 mb-6">Elérhetőségeink</h2>
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Inárcs</h3>
              <p class="text-gray-700">2345 Inárcs, Liget utca 12.</p>
              <p class="text-gray-600 text-sm">H–P: 08:00 – 18:00</p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Dabas</h3>
              <p class="text-gray-700">2370 Dabas, Szent István tér 5.</p>
              <p class="text-gray-600 text-sm">K–Cs: 09:00 – 17:00</p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Email</h3>
              <a href="mailto:info@lelekliget.hu" class="text-brand hover:underline">info@lelekliget.hu</a>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">Telefon</h3>
              <a href="tel:+36..." class="text-brand hover:underline">+36 …</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Kapcsolati form -->
      <div>
        <h2 class="text-2xl font-normal text-gray-900 mb-6">Írjon nekünk</h2>
        <!-- TODO: form action beállítása (pl. Web3Forms vagy Resend API) -->
        <form class="flex flex-col gap-4" name="contact" action="mailto:info@lelekliget.hu" method="GET">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-sm font-medium text-gray-700">Neve</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              placeholder="Kovács Anna"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-gray-700">Email cím</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              placeholder="anna@example.hu"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-medium text-gray-700">Üzenet</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="rounded-xl border border-gray-200 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand resize-none"
              placeholder="Írja ide kérdését…"
            ></textarea>
          </div>
          <button type="submit" class="btn-brand w-full justify-center">
            Üzenet küldése
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
